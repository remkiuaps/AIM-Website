---
import PageLayout from '../../../layouts/PageLayout.astro';
import PageHero from '../../../components/shared/PageHero.astro';
import AnimateOnScroll from '../../../components/ui/AnimateOnScroll.astro';
import { getContent, url } from '../../../i18n/utils';

const lang = 'pl' as const;
const content = getContent(lang);

export function getStaticPaths() {
  const plContent = getContent('pl');
  return plContent.solutions.items.map((solution) => ({
    params: { slug: solution.slug },
    props: { solution },
  }));
}

const { solution } = Astro.props;
---
<PageLayout lang={lang} title={`${solution.title} - AI Machine`} description={solution.shortDescription}>
  <PageHero title={solution.title} subtitle={solution.shortDescription} image={solution.image} />

  <section class="py-20 bg-brand-darker">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <AnimateOnScroll animation="fade-up">
        <div class="prose prose-lg prose-invert max-w-none">
          <p class="text-gray-300 text-lg leading-relaxed mb-12">
            {solution.fullDescription}
          </p>
        </div>
      </AnimateOnScroll>

      <!-- Features -->
      <AnimateOnScroll animation="fade-up" delay={200}>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-12">
          {solution.features.map((feature) => (
            <div class="flex items-center gap-3 p-4 rounded-xl bg-brand-card border border-white/5">
              <div class="flex items-center justify-center w-8 h-8 rounded-lg gradient-brand shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-gray-300 font-medium">{feature}</span>
            </div>
          ))}
        </div>
      </AnimateOnScroll>

      <!-- Image -->
      <AnimateOnScroll animation="fade-up" delay={300}>
        <div class="mt-16 rounded-2xl overflow-hidden aspect-video relative">
          <img
            src={url(solution.image)}
            alt={solution.title}
            class="w-full h-full object-cover"
            onerror="this.style.display='none'"
          />
          <div class="absolute inset-0 bg-gradient-to-br from-brand-teal/20 to-brand-green/20 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
            </svg>
          </div>
        </div>
      </AnimateOnScroll>

      <!-- Back link -->
      <div class="mt-12 text-center">
        <a href={url('/pl/rozwiazania/')} class="inline-flex items-center text-brand-green hover:text-brand-teal transition-colors font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Wróć do rozwiązań
        </a>
      </div>
    </div>
  </section>
</PageLayout>
