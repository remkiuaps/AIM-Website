---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/shared/PageHero.astro';
import AnimateOnScroll from '../../components/ui/AnimateOnScroll.astro';
import { getContent } from '../../i18n/utils';

const lang = 'pl' as const;
const content = getContent(lang);
const contact = content.contactPage;
const faq = (contact as any).faq;
const hours = (contact as any).hours;
const info = contact.info as any;
---
<PageLayout lang={lang} title={`${contact.title} - AI Machine`}>
  <PageHero title={contact.title} subtitle={contact.subtitle} image="/images/contact-hero.png" />

  <section class="py-20 bg-brand-darker">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Contact Form -->
        <AnimateOnScroll animation="fade-right">
          <div class="contact-glass p-8 rounded-2xl">
            <h2 class="text-2xl font-bold font-heading text-white mb-3">{contact.subtitle}</h2>
            <p class="text-gray-400 mb-8">{contact.description}</p>

            <form class="space-y-5" id="contact-form" action="https://api.web3forms.com/submit" method="POST">
              <input type="hidden" name="access_key" value="4bfb118d-18f8-4dfc-8f87-dbc9e5d13598" />
              <input type="hidden" name="subject" value="Nowa wiadomość z formularza - AI Machine" />
              <input type="hidden" name="from_name" value="AI Machine Website" />
              <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-gray-300 mb-2">{contact.form.name}</label>
                  <input type="text" id="name" name="name" required class="contact-input w-full px-4 py-3 rounded-lg text-white placeholder-gray-500 outline-none transition-all duration-300" />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-gray-300 mb-2">{contact.form.email}</label>
                  <input type="email" id="email" name="email" required class="contact-input w-full px-4 py-3 rounded-lg text-white placeholder-gray-500 outline-none transition-all duration-300" />
                </div>
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-gray-300 mb-2">{contact.form.company}</label>
                <input type="text" id="company" name="company" class="contact-input w-full px-4 py-3 rounded-lg text-white placeholder-gray-500 outline-none transition-all duration-300" />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-gray-300 mb-2">{contact.form.message}</label>
                <textarea id="message" name="message" rows="5" required class="contact-input w-full px-4 py-3 rounded-lg text-white placeholder-gray-500 outline-none transition-all duration-300 resize-none"></textarea>
              </div>

              <div class="h-captcha" data-captcha="true"></div>

              <button type="submit" id="submit-btn" class="w-full px-6 py-3.5 text-sm font-semibold text-white rounded-lg gradient-brand gradient-brand-hover transition-all duration-300 hover:shadow-lg hover:shadow-brand-green/20">
                <span id="btn-text">{contact.form.submit}</span>
                <svg id="btn-icon" xmlns="http://www.w3.org/2000/svg" class="inline-block ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
                <svg id="btn-spinner" class="animate-spin ml-2 h-4 w-4" style="display:none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
              </button>

              <div id="form-message" class="rounded-lg p-4 text-sm text-center" style="display:none"></div>
            </form>
          </div>
        </AnimateOnScroll>

        <!-- Contact Info -->
        <AnimateOnScroll animation="fade-left" delay={200}>
          <div class="space-y-6">
            <!-- Company Info Card -->
            <div class="contact-glass p-6 rounded-2xl">
              <h3 class="text-lg font-bold font-heading text-white mb-5">Dane kontaktowe</h3>
              <div class="space-y-4">
                <div class="flex items-start gap-4">
                  <div class="flex items-center justify-center w-10 h-10 rounded-lg gradient-brand shrink-0 mt-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm text-gray-400">Firma</p>
                    <p class="text-white font-medium">{info.companyName}</p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="flex items-center justify-center w-10 h-10 rounded-lg gradient-brand shrink-0 mt-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm text-gray-400">Adres</p>
                    <p class="text-white">{info.address}</p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="flex items-center justify-center w-10 h-10 rounded-lg gradient-brand shrink-0 mt-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm text-gray-400">Email</p>
                    <a href={`mailto:${info.email}`} class="text-white hover:text-brand-teal transition-colors">{info.email}</a>
                  </div>
                </div>
              </div>
            </div>

            <!-- Business Hours Card -->
            <div class="contact-glass p-6 rounded-2xl">
              <div class="flex items-start gap-4">
                <div class="flex items-center justify-center w-10 h-10 rounded-lg gradient-brand shrink-0 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-bold font-heading text-white mb-2">{hours.title}</h3>
                  <p class="text-gray-300">{hours.schedule}</p>
                  <p class="text-gray-500 text-sm mt-1">{hours.weekend}</p>
                </div>
              </div>
            </div>

            <!-- Google Maps -->
            <div class="contact-glass rounded-2xl overflow-hidden">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2452.5!2d21.08!3d51.99!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zS29yY3p1bmtvd2EgMjAsIDA1LTUwMyBHxYJvc2vDs3c!5e0!3m2!1spl!2spl!4v1"
                width="100%"
                height="220"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="AI Machine - Lokalizacja"
              ></iframe>
            </div>
          </div>
        </AnimateOnScroll>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  {faq && faq.items.length > 0 && (
    <section class="py-20 bg-brand-dark">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <AnimateOnScroll animation="fade-up">
          <div class="text-center mb-12">
            <h2 class="text-2xl sm:text-3xl font-heading font-bold text-white">{faq.title}</h2>
            <div class="mt-3 mx-auto w-16 h-[2px] bg-gradient-to-r from-brand-teal to-brand-green rounded-full"></div>
          </div>
        </AnimateOnScroll>

        <div class="space-y-4">
          {faq.items.map((item: any, index: number) => (
            <AnimateOnScroll animation="fade-up" delay={index * 80}>
              <div class="faq-glass rounded-xl overflow-hidden">
                <button
                  class="faq-toggle w-full flex items-center justify-between p-5 text-left"
                  data-faq-index={index}
                >
                  <span class="text-white font-medium pr-4">{item.question}</span>
                  <svg class="faq-chevron w-5 h-5 text-brand-teal shrink-0 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="faq-content" style="display:none">
                  <div class="px-5 pb-5">
                    <p class="text-gray-400 leading-relaxed">{item.answer}</p>
                  </div>
                </div>
              </div>
            </AnimateOnScroll>
          ))}
        </div>
      </div>
    </section>
  )}

  <script is:inline src="https://web3forms.com/client/script.js" async defer></script>

  <script is:inline>
    // Contact form
    document.getElementById('contact-form').addEventListener('submit', async function(e) {
      e.preventDefault();

      const form = e.target;
      const btn = document.getElementById('submit-btn');
      const btnText = document.getElementById('btn-text');
      const btnIcon = document.getElementById('btn-icon');
      const btnSpinner = document.getElementById('btn-spinner');
      const msg = document.getElementById('form-message');

      const originalText = btnText.textContent;
      btnText.textContent = 'Wysyłanie...';
      btnIcon.style.display = 'none';
      btnSpinner.style.display = 'inline-block';
      btn.disabled = true;

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
        });
        const data = await response.json();

        msg.className = 'rounded-lg p-4 text-sm text-center';
        msg.style.display = 'block';

        if (data.success) {
          msg.style.backgroundColor = 'rgba(34,197,94,0.1)';
          msg.style.color = '#4ade80';
          msg.textContent = 'Wiadomość wysłana pomyślnie! Odpowiemy najszybciej jak to możliwe.';
          form.reset();
        } else {
          msg.style.backgroundColor = 'rgba(239,68,68,0.1)';
          msg.style.color = '#f87171';
          msg.textContent = 'Coś poszło nie tak. Spróbuj ponownie lub skontaktuj się z nami bezpośrednio przez email.';
        }
      } catch (err) {
        msg.className = 'rounded-lg p-4 text-sm text-center';
        msg.style.display = 'block';
        msg.style.backgroundColor = 'rgba(239,68,68,0.1)';
        msg.style.color = '#f87171';
        msg.textContent = 'Coś poszło nie tak. Spróbuj ponownie lub skontaktuj się z nami bezpośrednio przez email.';
      } finally {
        btnText.textContent = originalText;
        btnIcon.style.display = 'inline-block';
        btnSpinner.style.display = 'none';
        btn.disabled = false;
      }
    });

    // FAQ accordion
    document.querySelectorAll('.faq-toggle').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const content = this.nextElementSibling;
        const chevron = this.querySelector('.faq-chevron');
        const isOpen = content.style.display !== 'none';

        // Close all
        document.querySelectorAll('.faq-content').forEach(function(c) { c.style.display = 'none'; });
        document.querySelectorAll('.faq-chevron').forEach(function(c) { c.classList.remove('rotate-180'); });

        // Open clicked if was closed
        if (!isOpen) {
          content.style.display = 'block';
          chevron.classList.add('rotate-180');
        }
      });
    });
  </script>
</PageLayout>

<style>
  .contact-glass {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }
  .contact-input {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .contact-input:focus {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(26, 138, 122, 0.5);
    box-shadow: 0 0 0 3px rgba(26, 138, 122, 0.1);
  }
  .faq-glass {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: border-color 0.3s;
  }
  .faq-glass:hover {
    border-color: rgba(26, 138, 122, 0.2);
  }
</style>
