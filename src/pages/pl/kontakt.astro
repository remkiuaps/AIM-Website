---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/shared/PageHero.astro';
import AnimateOnScroll from '../../components/ui/AnimateOnScroll.astro';
import { getContent } from '../../i18n/utils';

const lang = 'pl' as const;
const content = getContent(lang);
const contact = content.contactPage;
---
<PageLayout lang={lang} title={`${contact.title} - AI Machine`}>
  <PageHero title={contact.title} subtitle={contact.subtitle} />

  <section class="py-20 bg-brand-darker">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Contact Form -->
        <AnimateOnScroll animation="fade-right">
          <div class="p-8 rounded-2xl bg-brand-card border border-white/5">
            <h2 class="text-2xl font-bold font-heading text-white mb-6">{contact.subtitle}</h2>
            <p class="text-gray-400 mb-8">{contact.description}</p>

            <form class="space-y-5" id="contact-form">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-gray-300 mb-2">{contact.form.name}</label>
                  <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg bg-brand-darker border border-white/10 text-white placeholder-gray-500 focus:border-brand-teal focus:ring-1 focus:ring-brand-teal outline-none transition-colors" />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-gray-300 mb-2">{contact.form.email}</label>
                  <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg bg-brand-darker border border-white/10 text-white placeholder-gray-500 focus:border-brand-teal focus:ring-1 focus:ring-brand-teal outline-none transition-colors" />
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="phone" class="block text-sm font-medium text-gray-300 mb-2">{contact.form.phone}</label>
                  <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-lg bg-brand-darker border border-white/10 text-white placeholder-gray-500 focus:border-brand-teal focus:ring-1 focus:ring-brand-teal outline-none transition-colors" />
                </div>
                <div>
                  <label for="company" class="block text-sm font-medium text-gray-300 mb-2">{contact.form.company}</label>
                  <input type="text" id="company" name="company" class="w-full px-4 py-3 rounded-lg bg-brand-darker border border-white/10 text-white placeholder-gray-500 focus:border-brand-teal focus:ring-1 focus:ring-brand-teal outline-none transition-colors" />
                </div>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-gray-300 mb-2">{contact.form.message}</label>
                <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-lg bg-brand-darker border border-white/10 text-white placeholder-gray-500 focus:border-brand-teal focus:ring-1 focus:ring-brand-teal outline-none transition-colors resize-none"></textarea>
              </div>
              <button type="submit" class="w-full px-6 py-3 text-sm font-semibold text-white rounded-md gradient-brand gradient-brand-hover transition-all duration-300 hover:shadow-lg hover:shadow-brand-green/20">
                {contact.form.submit}
                <svg xmlns="http://www.w3.org/2000/svg" class="inline-block ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </button>
            </form>
          </div>
        </AnimateOnScroll>

        <!-- Contact Info -->
        <AnimateOnScroll animation="fade-left" delay={200}>
          <div class="space-y-8">
            <div>
              <h3 class="text-lg font-bold font-heading text-white mb-4">Dane kontaktowe</h3>
              <div class="space-y-4">
                <div class="flex items-start gap-4">
                  <div class="flex items-center justify-center w-10 h-10 rounded-lg gradient-brand shrink-0 mt-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm text-gray-400">Adres</p>
                    <p class="text-white">{contact.info.address}</p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="flex items-center justify-center w-10 h-10 rounded-lg gradient-brand shrink-0 mt-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm text-gray-400">Telefon</p>
                    <p class="text-white">{contact.info.phone}</p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="flex items-center justify-center w-10 h-10 rounded-lg gradient-brand shrink-0 mt-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm text-gray-400">Email</p>
                    <p class="text-white">{contact.info.email}</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Map placeholder -->
            <div class="rounded-2xl overflow-hidden aspect-video bg-brand-card border border-white/5 flex items-center justify-center">
              <div class="text-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-white/20 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
                </svg>
                <p class="text-gray-500 text-sm">Mapa</p>
              </div>
            </div>
          </div>
        </AnimateOnScroll>
      </div>
    </div>
  </section>
</PageLayout>
