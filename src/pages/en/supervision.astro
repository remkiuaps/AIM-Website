---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/shared/PageHero.astro';
import ContentSections from '../../components/shared/ContentSections.astro';
import { getContent } from '../../i18n/utils';

const lang = 'en' as const;
const content = getContent(lang);
const data = content.supervision;
---
<PageLayout lang={lang} title={`${data.heroTitle} - AI Machine`} description={data.description}>
  <PageHero title={data.heroTitle} subtitle={data.heroSubtitle} image={data.heroImage} />
  <section class="py-16 bg-brand-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-gray-300 text-lg leading-relaxed text-center">{data.description}</p>
    </div>
  </section>
  <ContentSections sections={data.sections} />
</PageLayout>
