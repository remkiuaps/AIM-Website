---
import PageLayout from '../../../layouts/PageLayout.astro';
import PageHero from '../../../components/shared/PageHero.astro';
import SolutionsSection from '../../../components/home/SolutionsSection.astro';
import { getContent } from '../../../i18n/utils';

const lang = 'en' as const;
const content = getContent(lang);
---
<PageLayout lang={lang} title={`${content.solutions.sectionTitle} - AI Machine`}>
  <PageHero
    title={content.solutions.sectionTitle}
    subtitle="We deliver advanced automation solutions for industry and buildings."
  />
  <SolutionsSection lang={lang} />
</PageLayout>
