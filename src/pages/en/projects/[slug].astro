---
import PageLayout from '../../../layouts/PageLayout.astro';
import PageHero from '../../../components/shared/PageHero.astro';
import AnimateOnScroll from '../../../components/ui/AnimateOnScroll.astro';
import { getContent, url } from '../../../i18n/utils';

const lang = 'en' as const;

export function getStaticPaths() {
  const enContent = getContent('en');
  return enContent.projects.items.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---
<PageLayout lang={lang} title={`${project.title} - AI Machine`} description={project.shortDescription}>
  <PageHero title={project.title} subtitle={project.shortDescription} image={project.image} />

  <section class="py-20 bg-brand-darker">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Project specs -->
      <AnimateOnScroll animation="fade-up">
        <div class="grid grid-cols-3 gap-4 mb-12">
          {Object.entries(project.specs).map(([key, value]) => (
            <div class="text-center p-4 rounded-xl bg-brand-card border border-white/5">
              <p class="text-sm text-gray-400 uppercase tracking-wider mb-1">{key === 'area' ? 'Area' : key === 'year' ? 'Year' : 'Location'}</p>
              <p class="text-lg font-bold text-white">{value}</p>
            </div>
          ))}
        </div>
      </AnimateOnScroll>

      <AnimateOnScroll animation="fade-up" delay={100}>
        <p class="text-gray-300 text-lg leading-relaxed mb-12">
          {project.fullDescription}
        </p>
      </AnimateOnScroll>

      <!-- Gallery -->
      <AnimateOnScroll animation="fade-up" delay={200}>
        <div class="grid grid-cols-1 gap-4">
          {project.gallery.map((img) => (
            <div class="rounded-2xl overflow-hidden aspect-video relative">
              <img
                src={url(img)}
                alt={project.title}
                class="w-full h-full object-cover"
                onerror="this.style.display='none'"
              />
              <div class="absolute inset-0 bg-gradient-to-br from-brand-teal/20 to-brand-green/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
                </svg>
              </div>
            </div>
          ))}
        </div>
      </AnimateOnScroll>

      <div class="mt-12 text-center">
        <a href={url('/en/projects/')} class="inline-flex items-center text-brand-green hover:text-brand-teal transition-colors font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Back to Projects
        </a>
      </div>
    </div>
  </section>
</PageLayout>
