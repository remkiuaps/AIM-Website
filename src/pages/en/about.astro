---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/shared/PageHero.astro';
import AnimateOnScroll from '../../components/ui/AnimateOnScroll.astro';
import { getContent } from '../../i18n/utils';

const lang = 'en' as const;
const content = getContent(lang);
const about = content.aboutPage;
---
<PageLayout lang={lang} title={`${about.title} - AI Machine`}>
  <PageHero title={about.title} subtitle={about.subtitle} />

  <section class="py-20 bg-brand-darker">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <AnimateOnScroll animation="fade-up">
        <p class="text-gray-300 text-lg leading-relaxed mb-8">{about.story}</p>
        <p class="text-gray-300 text-lg leading-relaxed mb-16">{about.mission}</p>
      </AnimateOnScroll>

      <!-- Values -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {about.values.map((value, index) => (
          <AnimateOnScroll animation="fade-up" delay={index * 100}>
            <div class="p-6 rounded-2xl bg-brand-card border border-white/5 hover:border-brand-teal/30 transition-all duration-300 hover:-translate-y-1">
              <div class="w-12 h-12 rounded-xl gradient-brand flex items-center justify-center mb-4">
                <span class="text-white font-bold text-lg">{index + 1}</span>
              </div>
              <h3 class="text-xl font-bold font-heading text-white mb-2">{value.title}</h3>
              <p class="text-gray-400">{value.description}</p>
            </div>
          </AnimateOnScroll>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
