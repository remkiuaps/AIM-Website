---
import { languages } from '../../i18n/config';
import { getAlternateUrl } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
---
<div role="group" aria-label="Language" class="flex items-center gap-1 rounded-lg bg-white/5 p-1">
  {Object.entries(languages).map(([code, label]) => (
    <a
      href={getAlternateUrl(currentPath, code as Lang)}
      class:list={[
        'px-2 py-1 text-xs font-semibold rounded transition-all duration-200',
        code === lang
          ? 'gradient-brand text-white'
          : 'text-gray-400 hover:text-white',
      ]}
      aria-current={code === lang ? 'page' : undefined}
      title={label}
    >
      {code.toUpperCase()}
    </a>
  ))}
</div>
