---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  class?: string;
}

const { title, subtitle, centered = true, class: className = '' } = Astro.props;
---
<div class:list={[centered ? 'text-center' : '', 'mb-12', className]}>
  <h2 class="text-3xl md:text-4xl font-bold font-heading text-white mb-3">
    {title}
  </h2>
  {subtitle && (
    <p class="text-gray-400 text-lg max-w-2xl mx-auto">
      {subtitle}
    </p>
  )}
</div>
