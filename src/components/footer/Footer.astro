---
import type { Lang } from '../../i18n/config';
import { getContent, getContactUrl, url } from '../../i18n/utils';
import SocialIcons from './SocialIcons.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = getContent(lang);
const footer = content.footer;
const contactUrl = getContactUrl(lang);
---
<!-- CTA Section -->
<section class="relative py-24 overflow-hidden">
  <div class="absolute inset-0 bg-brand-darker"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-brand-darker via-brand-dark/50 to-brand-darker"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-brand-teal/5 blur-3xl"></div>
  <div class="absolute top-1/2 left-1/3 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] rounded-full bg-brand-green/5 blur-3xl"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <div class="aos-element" data-aos="fade-up">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading mb-2">
        {footer.ctaTitle}
      </h2>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading gradient-text mb-8">
        {footer.ctaBrand}
      </h2>
      <a href={contactUrl} class="inline-flex items-center px-8 py-4 text-lg font-semibold text-white rounded-md gradient-brand gradient-brand-hover transition-all duration-300 hover:shadow-xl hover:shadow-brand-green/20 hover:-translate-y-0.5">
        {footer.ctaButton}
        <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="bg-brand-darker border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8 lg:gap-12">
      <!-- Brand column -->
      <div class="col-span-2 md:col-span-4 lg:col-span-1 mb-4 lg:mb-0">
        <a href={url(`/${lang}/`)} class="inline-block mb-4">
          <img src={url('/images/logo.png')} alt="AI Machine" class="h-12 w-auto" />
        </a>
        <p class="text-sm text-gray-400 mb-6 max-w-xs">
          {content.meta.siteDescription}
        </p>
        <SocialIcons social={footer.social} />
      </div>

      <!-- Link columns -->
      {footer.columns.map((column) => (
        <div>
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
            {column.title}
          </h3>
          <ul class="space-y-3">
            {column.links.map((link) => (
              <li>
                <a href={url(link.href)} class="text-sm text-gray-400 hover:text-brand-green transition-colors duration-200">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-500">{footer.copyright}</p>
      <p class="text-sm text-gray-500">The Future of Automation</p>
    </div>
  </div>
</footer>
