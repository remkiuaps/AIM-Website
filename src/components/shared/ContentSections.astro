---
import AnimateOnScroll from '../ui/AnimateOnScroll.astro';
import { url } from '../../i18n/utils';

interface Section {
  title: string;
  description: string;
  image: string;
}

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---
<section class="py-20 lg:py-28 bg-brand-darker">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="space-y-20">
      {sections.map((section, index) => (
        <AnimateOnScroll animation={index % 2 === 0 ? 'fade-right' : 'fade-left'}>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
            <div class:list={[index % 2 !== 0 && 'lg:order-2']}>
              <h2 class="text-2xl md:text-3xl font-bold font-heading text-white mb-4">
                {section.title}
              </h2>
              <p class="text-gray-400 text-lg leading-relaxed">
                {section.description}
              </p>
            </div>
            <div class:list={['relative rounded-2xl overflow-hidden aspect-video', index % 2 !== 0 && 'lg:order-1']}>
              <img
                src={url(section.image)}
                alt={section.title}
                class="w-full h-full object-cover"
                onerror="this.style.display='none'"
              />
            </div>
          </div>
        </AnimateOnScroll>
      ))}
    </div>
  </div>
</section>
