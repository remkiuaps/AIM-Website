---
import AnimateOnScroll from '../ui/AnimateOnScroll.astro';
import { url } from '../../i18n/utils';

interface Section {
  title: string;
  description: string;
  image: string;
}

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---
<section class="py-20 lg:py-28 bg-brand-darker">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="space-y-20">
      {sections.map((section, index) => (
        <AnimateOnScroll animation={index % 2 === 0 ? 'fade-right' : 'fade-left'}>
          <div class:list={['grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center', index % 2 !== 0 && 'lg:flex-row-reverse']}>
            <div class:list={[index % 2 !== 0 && 'lg:order-2']}>
              <h2 class="text-2xl md:text-3xl font-bold font-heading text-white mb-4">
                {section.title}
              </h2>
              <p class="text-gray-400 text-lg leading-relaxed">
                {section.description}
              </p>
            </div>
            <div class:list={['relative rounded-2xl overflow-hidden aspect-video', index % 2 !== 0 && 'lg:order-1']}>
              <img
                src={url(section.image)}
                alt={section.title}
                class="w-full h-full object-cover"
                onerror="this.style.display='none'"
              />
              <div class="absolute inset-0 bg-gradient-to-br from-brand-teal/20 to-brand-green/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
                </svg>
              </div>
            </div>
          </div>
        </AnimateOnScroll>
      ))}
    </div>
  </div>
</section>
