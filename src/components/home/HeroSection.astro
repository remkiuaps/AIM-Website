---
import type { Lang } from '../../i18n/config';
import { getContent, url } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = getContent(lang);
const hero = content.hero;
---
<section class="relative min-h-screen pt-16 lg:pt-20">
  <div class="relative min-h-[calc(100vh-5rem)] flex flex-col lg:block overflow-hidden">
    <!-- Left Panel - Intelligent Machines -->
    <div class="hero-panel-left relative group overflow-hidden min-h-[50vh] lg:min-h-full lg:absolute lg:inset-0 lg:w-full">
      <!-- Background image -->
      <div class="absolute inset-0 bg-brand-dark">
        <img
          src={url(hero.left.image)}
          alt={hero.left.title}
          class="w-full h-full object-cover opacity-60 group-hover:opacity-70 group-hover:scale-105 transition-all duration-700"
          onerror="this.style.display='none'"
        />
      </div>
      <!-- Overlay gradient -->
      <div class="absolute inset-0 bg-gradient-to-t from-brand-darker via-brand-darker/40 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-brand-darker/30 to-transparent"></div>

      <!-- Content -->
      <div class="relative z-10 flex flex-col justify-end h-full p-8 lg:p-12 xl:p-16 pb-12 lg:pb-16 lg:w-1/2">
        <div class="aos-element" data-aos="fade-up">
          <h1 class="text-4xl md:text-5xl xl:text-6xl font-bold font-heading text-white mb-3 leading-tight">
            {hero.left.title}
          </h1>
          <p class="text-lg md:text-xl text-gray-300 mb-8">
            {hero.left.subtitle}
          </p>
          <a
            href={url(hero.left.ctaLink)}
            class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white rounded-md gradient-brand gradient-brand-hover transition-all duration-300 hover:shadow-lg hover:shadow-brand-green/30 hover:-translate-y-0.5"
          >
            {hero.left.cta}
            <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Right Panel - Intelligent Buildings -->
    <div class="hero-panel-right relative group overflow-hidden min-h-[50vh] lg:min-h-full lg:absolute lg:inset-0 lg:w-full">
      <!-- Background image -->
      <div class="absolute inset-0 bg-brand-dark">
        <img
          src={url(hero.right.image)}
          alt={hero.right.title}
          class="w-full h-full object-cover opacity-60 group-hover:opacity-70 group-hover:scale-105 transition-all duration-700"
          onerror="this.style.display='none'"
        />
      </div>
      <!-- Overlay gradient -->
      <div class="absolute inset-0 bg-gradient-to-t from-brand-darker via-brand-darker/40 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-l from-brand-darker/30 to-transparent"></div>

      <!-- Content -->
      <div class="relative z-10 flex flex-col justify-end h-full p-8 lg:p-12 xl:p-16 pb-12 lg:pb-16 lg:ml-auto lg:w-1/2">
        <div class="aos-element" data-aos="fade-up" data-aos-delay="200">
          <h2 class="text-4xl md:text-5xl xl:text-6xl font-bold font-heading text-white mb-3 leading-tight">
            {hero.right.title}
          </h2>
          <p class="text-lg md:text-xl text-gray-300 mb-8">
            {hero.right.subtitle}
          </p>
          <a
            href={url(hero.right.ctaLink)}
            class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white rounded-md border border-brand-green bg-brand-green/10 hover:bg-brand-green/20 transition-all duration-300 hover:-translate-y-0.5"
          >
            {hero.right.cta}
            <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Golden diagonal line between panels -->
    <div class="hidden lg:block absolute inset-0 z-20 pointer-events-none">
      <svg class="w-full h-full" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="hero-gold-gradient" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="rgba(245, 158, 11, 0.6)" />
            <stop offset="50%" stop-color="rgba(251, 191, 36, 0.4)" />
            <stop offset="100%" stop-color="rgba(245, 158, 11, 0.6)" />
          </linearGradient>
        </defs>
        <line x1="53%" y1="0" x2="47%" y2="100%" stroke="url(#hero-gold-gradient)" stroke-width="2" />
      </svg>
    </div>
  </div>

  <!-- Diagonal separator -->
  <div class="absolute bottom-0 left-0 right-0 h-16 bg-brand-darker" style="clip-path: polygon(0 100%, 100% 100%, 100% 0, 0 100%);"></div>
</section>

<style>
  @media (min-width: 1024px) {
    .hero-panel-left {
      clip-path: polygon(0 0, 53% 0, 47% 100%, 0 100%);
      z-index: 1;
    }
    .hero-panel-right {
      clip-path: polygon(53% 0, 100% 0, 100% 100%, 47% 100%);
      z-index: 1;
    }
  }
</style>
