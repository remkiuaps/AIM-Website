---
import type { Lang } from '../../i18n/config';
import { getContent, url } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = getContent(lang);
const hero = content.hero;
---
<section class="relative min-h-screen pt-16 lg:pt-20">
  <div class="relative min-h-[calc(100vh-5rem)] overflow-hidden">
    <!-- Slider track: flex horizontal on mobile, block on desktop -->
    <div id="hero-slider-track" class="hero-slider-track flex lg:block min-h-[calc(100vh-5rem)]">

      <!-- Left Panel - Intelligent Machines -->
      <div class="hero-panel-left min-w-full shrink-0 grow-0 basis-full relative group overflow-hidden min-h-[calc(100vh-5rem)] lg:min-h-full lg:absolute lg:inset-0 lg:w-full lg:min-w-0 lg:basis-auto">
        <!-- Background image -->
        <div class="absolute inset-0 lg:right-auto lg:w-[53%] bg-brand-dark">
          <img
            src={url(hero.left.image)}
            alt={hero.left.title}
            class="w-full h-full object-cover object-center opacity-80 group-hover:opacity-90 group-hover:scale-105 transition-all duration-700"
            onerror="this.style.display='none'"
          />
        </div>
        <!-- Overlay gradient -->
        <div class="absolute inset-0 bg-gradient-to-t from-brand-darker via-brand-darker/20 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-brand-darker/20 to-transparent"></div>

        <!-- Content -->
        <div class="relative z-10 flex flex-col justify-end h-full p-8 lg:p-12 xl:p-16 pb-28 lg:pb-16 lg:w-1/2">
          <div class="aos-element" data-aos="fade-up">
            <h1 class="text-4xl md:text-5xl xl:text-6xl font-bold font-heading text-white mb-3 leading-tight">
              {hero.left.title}
            </h1>
            <p class="text-lg md:text-xl text-gray-300 mb-8">
              {hero.left.subtitle}
            </p>
            <a
              href={url(hero.left.ctaLink)}
              class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white rounded gradient-brand gradient-brand-hover transition-all duration-300 hover:shadow-lg hover:shadow-brand-green/30 hover:-translate-y-0.5"
            >
              {hero.left.cta}
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Right Panel - Intelligent Buildings -->
      <div class="hero-panel-right min-w-full shrink-0 grow-0 basis-full relative group overflow-hidden min-h-[calc(100vh-5rem)] lg:min-h-full lg:absolute lg:inset-0 lg:w-full lg:min-w-0 lg:basis-auto">
        <!-- Background image -->
        <div class="absolute inset-0 lg:left-auto lg:w-[53%] bg-brand-dark">
          <img
            src={url(hero.right.image)}
            alt={hero.right.title}
            class="w-full h-full object-cover object-center opacity-80 group-hover:opacity-90 group-hover:scale-105 transition-all duration-700"
            onerror="this.style.display='none'"
          />
        </div>
        <!-- Overlay gradient -->
        <div class="absolute inset-0 bg-gradient-to-t from-brand-darker via-brand-darker/20 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-l from-brand-darker/20 to-transparent"></div>

        <!-- Content -->
        <div class="relative z-10 flex flex-col justify-end h-full p-8 lg:p-12 xl:p-16 pb-28 lg:pb-16 lg:ml-auto lg:w-1/2">
          <div class="aos-element" data-aos="fade-up" data-aos-delay="200">
            <h2 class="text-4xl md:text-5xl xl:text-6xl font-bold font-heading text-white mb-3 leading-tight">
              {hero.right.title}
            </h2>
            <p class="text-lg md:text-xl text-gray-300 mb-8">
              {hero.right.subtitle}
            </p>
            <a
              href={url(hero.right.ctaLink)}
              class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white rounded border border-brand-green bg-brand-green/10 hover:bg-brand-green/20 transition-all duration-300 hover:-translate-y-0.5"
            >
              {hero.right.cta}
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>

    </div>

    <!-- Slider dots (mobile only) -->
    <div class="flex lg:hidden justify-center gap-3 absolute bottom-20 left-0 right-0 z-30">
      <button class="hero-dot active" data-slide="0" aria-label="Slide 1"></button>
      <button class="hero-dot" data-slide="1" aria-label="Slide 2"></button>
    </div>

    <!-- Golden diagonal line between panels (desktop only) -->
    <div class="hidden lg:block absolute inset-0 z-20 pointer-events-none">
      <svg class="w-full h-full" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="hero-gold-gradient" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="rgba(245, 158, 11, 0.6)" />
            <stop offset="50%" stop-color="rgba(251, 191, 36, 0.4)" />
            <stop offset="100%" stop-color="rgba(245, 158, 11, 0.6)" />
          </linearGradient>
        </defs>
        <line x1="53%" y1="0" x2="47%" y2="100%" stroke="url(#hero-gold-gradient)" stroke-width="2" />
      </svg>
    </div>

    <!-- Scroll down arrow -->
    <a href="#about" class="hero-scroll-arrow absolute bottom-8 left-1/2 -translate-x-1/2 z-30 cursor-pointer" aria-label="Scroll down">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white/40 hover:text-white/70 transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </div>

  <!-- Diagonal separator -->
  <div class="absolute bottom-0 left-0 right-0 h-16 bg-brand-darker" style="clip-path: polygon(0 100%, 100% 100%, 100% 0, 0 100%);"></div>
</section>

<style>
  /* Desktop split panels */
  @media (min-width: 1024px) {
    .hero-panel-left {
      clip-path: polygon(0 0, 53% 0, 47% 100%, 0 100%);
      z-index: 1;
    }
    .hero-panel-right {
      clip-path: polygon(53% 0, 100% 0, 100% 100%, 47% 100%);
      z-index: 1;
    }
  }

  /* Mobile slider track */
  .hero-slider-track {
    transition: transform 0.5s ease-in-out;
  }
  @media (min-width: 1024px) {
    .hero-slider-track {
      transition: none;
    }
  }

  /* Slider dots */
  .hero-dot {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.3);
    transition: background-color 0.3s, width 0.3s;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .hero-dot:hover {
    background: rgba(255, 255, 255, 0.5);
  }
  .hero-dot.active {
    width: 1.5rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.8);
  }

  /* Scroll arrow bounce */
  .hero-scroll-arrow {
    animation: hero-bounce 2s ease-in-out infinite;
  }
  @keyframes hero-bounce {
    0%, 100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(8px);
    }
  }
</style>

<script>
  (function () {
    const track = document.getElementById('hero-slider-track');
    const dots = document.querySelectorAll<HTMLButtonElement>('.hero-dot');
    if (!track || dots.length === 0) return;

    const INTERVAL = 5000;
    const SWIPE_THRESHOLD = 50;
    const TOTAL = 2;
    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let startX = 0;

    const isMobile = () => window.innerWidth < 1024;

    function goTo(i: number) {
      current = i;
      if (isMobile()) {
        track.style.transform = `translateX(-${i * 50}%)`;
      }
      dots.forEach((d, idx) => {
        d.classList.toggle('active', idx === i);
      });
    }

    function next() {
      if (isMobile()) goTo((current + 1) % TOTAL);
    }

    function startAuto() {
      stopAuto();
      timer = setInterval(next, INTERVAL);
    }

    function stopAuto() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    // Dot clicks
    dots.forEach((d) =>
      d.addEventListener('click', () => {
        goTo(parseInt(d.dataset.slide ?? '0'));
        startAuto();
      })
    );

    // Touch swipe
    track.addEventListener('touchstart', (e) => {
      if (!isMobile()) return;
      startX = e.changedTouches[0].screenX;
      stopAuto();
    }, { passive: true });

    track.addEventListener('touchend', (e) => {
      if (!isMobile()) return;
      const diff = startX - e.changedTouches[0].screenX;
      if (Math.abs(diff) > SWIPE_THRESHOLD) {
        if (diff > 0 && current < TOTAL - 1) goTo(current + 1);
        else if (diff < 0 && current > 0) goTo(current - 1);
      }
      startAuto();
    }, { passive: true });

    // Handle viewport change
    const mql = window.matchMedia('(max-width: 1023px)');
    mql.addEventListener('change', (e) => {
      if (e.matches) {
        goTo(current);
        startAuto();
      } else {
        stopAuto();
        track.style.transform = '';
      }
    });

    // Init
    if (isMobile()) startAuto();
  })();

  // Scroll arrow
  document.querySelector('.hero-scroll-arrow')?.addEventListener('click', (e) => {
    e.preventDefault();
    document.querySelector('#about')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
