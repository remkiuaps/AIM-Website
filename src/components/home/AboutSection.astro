---
import type { Lang } from '../../i18n/config';
import { getContent, url } from '../../i18n/utils';
import AnimateOnScroll from '../ui/AnimateOnScroll.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = getContent(lang);
const about = content.aboutSection;

const iconImages: Record<string, string> = {
  industrial: '/images/icon-industrial.png',
  smart: '/images/icon-smart.png',
};
---
<section id="about" class="py-16 lg:py-20 bg-brand-dark relative overflow-hidden">
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <AnimateOnScroll animation="fade-up">
      <!-- Logo -->
      <div class="flex justify-center mb-5">
        <img src={url('/images/logo.png')} alt="AI Machine" class="h-14 w-auto" />
      </div>

      <!-- Company name -->
      <h2 class="text-2xl md:text-3xl font-bold font-heading text-white tracking-wide mb-3">
        <span class="gradient-text">AI</span> MACHINE
      </h2>

      <!-- Description -->
      <p class="text-gray-400 text-sm md:text-base max-w-2xl mx-auto mb-12">
        {about.description}
      </p>
    </AnimateOnScroll>

    <!-- Features row -->
    <AnimateOnScroll animation="fade-up" delay={150}>
      <div class="inline-flex flex-col md:flex-row items-center justify-center gap-8 md:gap-12">
        <!-- Industrial Automation -->
        <div class="flex items-center gap-4">
          <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-brand-blue/10 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-blue-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
            </svg>
          </div>
          <div class="text-left">
            <h3 class="text-white font-semibold text-base">
              {about.features[0].title}
            </h3>
            <p class="text-gray-500 text-sm">
              {about.features[0].description}
            </p>
          </div>
        </div>

        <!-- Separator -->
        <div class="hidden md:block w-px h-10 bg-white/10"></div>

        <!-- Smart Infrastructure -->
        <div class="flex items-center gap-4">
          <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-brand-green/10 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
            </svg>
          </div>
          <div class="text-left">
            <h3 class="text-white font-semibold text-base">
              {about.features[1].title}
            </h3>
            <p class="text-gray-500 text-sm">
              {about.features[1].description}
            </p>
          </div>
        </div>
      </div>
    </AnimateOnScroll>
  </div>
</section>
