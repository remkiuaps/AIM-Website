---
import type { Lang } from '../../i18n/config';
import { getContent, url } from '../../i18n/utils';
import AnimateOnScroll from '../ui/AnimateOnScroll.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = getContent(lang);
const about = content.aboutSection;

const iconImages: Record<string, string> = {
  industrial: '/images/icon-industrial.png',
  smart: '/images/icon-smart.png',
};
---
<section class="py-16 lg:py-20 bg-brand-dark relative overflow-hidden">
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <AnimateOnScroll animation="fade-up">
      <!-- Logo -->
      <div class="flex justify-center mb-5">
        <img src={url('/images/logo.png')} alt="AI Machine" class="h-14 w-auto" />
      </div>

      <!-- Company name -->
      <h2 class="text-2xl md:text-3xl font-bold font-heading text-white tracking-wide mb-3">
        <span class="gradient-text">AI</span> MACHINE
      </h2>

      <!-- Description -->
      <p class="text-gray-400 text-sm md:text-base max-w-2xl mx-auto mb-12">
        {about.description}
      </p>
    </AnimateOnScroll>

    <!-- Features row -->
    <AnimateOnScroll animation="fade-up" delay={150}>
      <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-0">
        <!-- Industrial Automation -->
        <div class="flex items-center gap-4 px-8">
          <img
            src={url(iconImages[about.features[0].icon] || iconImages.industrial)}
            alt={about.features[0].title}
            class="w-12 h-12 object-contain shrink-0"
          />
          <div class="text-left">
            <h3 class="text-white font-semibold text-sm md:text-base">
              {about.features[0].title}
            </h3>
            <p class="text-gray-500 text-xs md:text-sm">
              {about.features[0].description}
            </p>
          </div>
        </div>

        <!-- Separator -->
        <div class="hidden md:block w-px h-12 bg-white/10 shrink-0"></div>
        <div class="md:hidden w-24 h-px bg-white/10"></div>

        <!-- Smart Infrastructure -->
        <div class="flex items-center gap-4 px-8">
          <img
            src={url(iconImages[about.features[1].icon] || iconImages.smart)}
            alt={about.features[1].title}
            class="w-12 h-12 object-contain shrink-0"
          />
          <div class="text-left">
            <h3 class="text-white font-semibold text-sm md:text-base">
              {about.features[1].title}
            </h3>
            <p class="text-gray-500 text-xs md:text-sm">
              {about.features[1].description}
            </p>
          </div>
        </div>
      </div>
    </AnimateOnScroll>
  </div>
</section>
