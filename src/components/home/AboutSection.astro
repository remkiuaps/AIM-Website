---
import type { Lang } from '../../i18n/config';
import { getContent, url } from '../../i18n/utils';
import AnimateOnScroll from '../ui/AnimateOnScroll.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = getContent(lang);
const about = content.aboutSection;
---
<section class="py-20 lg:py-28 bg-brand-dark relative overflow-hidden">
  <!-- Subtle background pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-brand-teal blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full bg-brand-green blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <AnimateOnScroll animation="fade-up">
      <!-- Logo mark -->
      <div class="flex justify-center mb-6">
        <img src={url('/images/logo.png')} alt="AI Machine" class="h-16 w-auto" />
      </div>

      <h2 class="text-3xl md:text-4xl font-bold font-heading gradient-text mb-4">
        {about.companyName}
      </h2>
      <p class="text-gray-300 text-lg md:text-xl max-w-3xl mx-auto mb-16">
        {about.description}
      </p>
    </AnimateOnScroll>

    <!-- Feature cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {about.features.map((feature, index) => (
        <AnimateOnScroll animation={index === 0 ? 'fade-right' : 'fade-left'} delay={index * 150}>
          <div class="group relative p-8 rounded-2xl bg-brand-darker/50 border border-white/5 hover:border-brand-teal/30 transition-all duration-300 hover:-translate-y-1">
            <!-- Icon -->
            <div class="flex items-center gap-4 mb-4">
              <div class="flex items-center justify-center w-14 h-14 rounded-xl gradient-brand shrink-0">
                {feature.icon === 'industrial' ? (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                )}
              </div>
              <h3 class="text-xl font-bold font-heading text-white">{feature.title}</h3>
            </div>
            <p class="text-gray-400">{feature.description}</p>

            <!-- Hover glow -->
            <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-gradient-to-br from-brand-teal/5 to-brand-green/5 pointer-events-none"></div>
          </div>
        </AnimateOnScroll>
      ))}
    </div>
  </div>
</section>
