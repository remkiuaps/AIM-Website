---
import type { Lang } from '../../i18n/config';
import { getContent, url } from '../../i18n/utils';
import SectionHeading from '../ui/SectionHeading.astro';
import AnimateOnScroll from '../ui/AnimateOnScroll.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = getContent(lang);
const projects = content.projects;
const projectsBase = url(lang === 'pl' ? '/pl/projekty' : '/en/projects');
---
<section id="projects" class="py-20 lg:py-28 bg-brand-dark relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <AnimateOnScroll animation="fade-up">
      <SectionHeading title={projects.sectionTitle} centered={false} />
    </AnimateOnScroll>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 auto-rows-fr">
      {projects.items.map((project, index) => (
        <AnimateOnScroll animation="fade-up" delay={index * 100}>
          <a
            href={`${projectsBase}/${project.slug}/`}
            class="group relative overflow-hidden rounded-2xl bg-brand-card border border-white/5 hover:border-brand-teal/30 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:shadow-brand-teal/10"
          >
            <!-- Image -->
            <div class="relative aspect-[3/2] overflow-hidden">
              <img
                src={url(project.image)}
                alt={project.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                onerror="this.style.display='none'"
              />
              <!-- Overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-brand-darker via-transparent to-transparent opacity-60"></div>
              <!-- Category badge -->
              <span class="absolute top-3 left-3 px-3 py-1 text-xs font-semibold text-white rounded-full gradient-brand">
                {project.category}
              </span>
            </div>

            <!-- Content -->
            <div class="p-5">
              <h3 class="text-lg font-bold font-heading text-white mb-1 group-hover:text-brand-green transition-colors">
                {project.title}
              </h3>
              <p class="text-sm text-gray-400 line-clamp-2">
                {project.shortDescription}
              </p>
            </div>
          </a>
        </AnimateOnScroll>
      ))}
    </div>
  </div>
</section>
