---
import type { Lang } from '../../i18n/config';
import { getContent, url } from '../../i18n/utils';
import SectionHeading from '../ui/SectionHeading.astro';
import AnimateOnScroll from '../ui/AnimateOnScroll.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = getContent(lang);
const solutions = content.solutions;
const solutionsBase = url(lang === 'pl' ? '/pl/rozwiazania' : '/en/solutions');

const blueIcons = new Set(['amr-agv', 'warehouse-automation']);

// removed inline SVG map as we use actual images now
---
<section class="py-20 lg:py-28 bg-brand-darker relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <AnimateOnScroll animation="fade-up">
      <SectionHeading title={solutions.sectionTitle} centered={false} />
    </AnimateOnScroll>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {solutions.items.map((solution, index) => (
        <AnimateOnScroll animation="fade-up" delay={index * 100}>
          <a
            href={`${solutionsBase}/${solution.slug}/`}
            class:list={[
              'group relative flex flex-col items-center p-6 lg:p-8 rounded-2xl bg-brand-card border border-white/5 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl',
              blueIcons.has(solution.slug) ? 'hover:border-brand-blue/30 hover:shadow-brand-blue/10' : 'hover:border-brand-teal/30 hover:shadow-brand-teal/10',
            ]}
          >
            <!-- Icon -->
            <div class="flex items-center justify-center w-20 h-20 mb-4 transition-transform duration-300 group-hover:scale-110">
              <img 
                src={solution.icon} 
                alt={solution.title} 
                class="w-full h-full object-contain mix-blend-screen drop-shadow-[0_0_15px_rgba(255,255,255,0.2)]"
              />
            </div>

            <!-- Title -->
            <h3 class:list={[
              'text-lg font-bold font-heading text-white text-center mb-2 transition-colors',
              blueIcons.has(solution.slug) ? 'group-hover:text-brand-blue-light' : 'group-hover:text-brand-green',
            ]}>
              {solution.title}
            </h3>

            <p class="text-sm text-gray-400 text-center">
              {solution.shortDescription}
            </p>

            <!-- Hover glow -->
            <div class:list={[
              'absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none',
              blueIcons.has(solution.slug) ? 'bg-gradient-to-br from-brand-blue/5 to-brand-blue-light/5' : 'bg-gradient-to-br from-brand-teal/5 to-brand-green/5',
            ]}></div>
          </a>
        </AnimateOnScroll>
      ))}
    </div>
  </div>
</section>
