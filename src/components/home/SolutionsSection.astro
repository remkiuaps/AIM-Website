---
import type { Lang } from '../../i18n/config';
import { getContent, url } from '../../i18n/utils';
import SectionHeading from '../ui/SectionHeading.astro';
import AnimateOnScroll from '../ui/AnimateOnScroll.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = getContent(lang);
const solutions = content.solutions;
const solutionsBase = url(lang === 'pl' ? '/pl/rozwiazania' : '/en/solutions');

const blueIcons = new Set(['amr-agv', 'warehouse-automation']);

const iconMap: Record<string, string> = {
  'amr-agv': '<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21M3.375 14.25h.008M21 14.25h-5.625m0 0V6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v7.5h10.875z" />',
  'warehouse-automation': '<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />',
  'service-robots': '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />',
  'smart-security': '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />',
};
---
<section class="py-20 lg:py-28 bg-brand-darker relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <AnimateOnScroll animation="fade-up">
      <SectionHeading title={solutions.sectionTitle} centered={false} />
    </AnimateOnScroll>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {solutions.items.map((solution, index) => (
        <AnimateOnScroll animation="fade-up" delay={index * 100}>
          <a
            href={`${solutionsBase}/${solution.slug}/`}
            class:list={[
              'group relative flex flex-col items-center p-6 lg:p-8 rounded-2xl bg-brand-card border border-white/5 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl',
              blueIcons.has(solution.slug) ? 'hover:border-brand-blue/30 hover:shadow-brand-blue/10' : 'hover:border-brand-teal/30 hover:shadow-brand-teal/10',
            ]}
          >
            <!-- Icon -->
            <div class:list={[
              'flex items-center justify-center w-16 h-16 rounded-2xl mb-5 group-hover:shadow-lg transition-shadow duration-300',
              blueIcons.has(solution.slug) ? 'gradient-blue group-hover:shadow-brand-blue/20' : 'gradient-brand group-hover:shadow-brand-green/20',
            ]}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <Fragment set:html={iconMap[solution.slug] || iconMap['amr-agv']} />
              </svg>
            </div>

            <!-- Title -->
            <h3 class:list={[
              'text-lg font-bold font-heading text-white text-center mb-2 transition-colors',
              blueIcons.has(solution.slug) ? 'group-hover:text-brand-blue-light' : 'group-hover:text-brand-green',
            ]}>
              {solution.title}
            </h3>

            <p class="text-sm text-gray-400 text-center">
              {solution.shortDescription}
            </p>

            <!-- Hover glow -->
            <div class:list={[
              'absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none',
              blueIcons.has(solution.slug) ? 'bg-gradient-to-br from-brand-blue/5 to-brand-blue-light/5' : 'bg-gradient-to-br from-brand-teal/5 to-brand-green/5',
            ]}></div>
          </a>
        </AnimateOnScroll>
      ))}
    </div>
  </div>
</section>
